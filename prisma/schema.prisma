generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id              String         @id @default(uuid())
  type            String         // "pickup" or "dropoff"
  phone           String
  status          String         @default("pending")
  branch          String?        // branch for the appointment
  date            DateTime       @default(now())
  createdAt       DateTime       @default(now())

  // Link to the pending parcel this appointment is for (for receive shipments)
  pendingParcelId String?
  pendingParcel   PendingParcel? @relation(fields: [pendingParcelId], references: [id])
}

model PendingParcel {
  id             String   @id @default(uuid())
  trackingNumber String   @unique
  status         String   @default("ready_for_pickup")
  branch         String
  phone          String
  createdAt      DateTime @default(now())

  appointments   Appointment[]
}
